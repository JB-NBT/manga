@startuml Diagramme_Sequence_Copyright
title Séquence - Gestion de l'Expiration Copyright

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2
skinparam participant {
    BackgroundColor #E8F4FD
    BorderColor #2980B9
}

actor "Modérateur" as M
participant "CopyrightController" as CC
participant "Manga (scope)" as Manga
database "Base de données" as DB

== Consultation des mangas expirés ==
M -> CC : GET /admin/copyright
activate CC
CC -> Manga : scopeExpired()
activate Manga
Manga -> DB : SELECT mangas WHERE est_public=1\nAND (date_republication < NOW()-1an\nOR created_at < NOW()-1an)
DB --> Manga : liste des mangas expirés
Manga --> CC : Collection<Manga>
deactivate Manga

CC -> Manga : scopeExpiringSoon()
activate Manga
Manga -> DB : SELECT mangas bientôt expirés (< 30j)
DB --> Manga : liste
Manga --> CC : Collection<Manga>
deactivate Manga

CC --> M : Vue avec mangas expirés + bientôt expirés
deactivate CC

== Dépublication automatique (expiration) ==
note over Manga : Vérification via isExpired()
M -> CC : (optionnel) Retrait manuel
CC -> Manga : unpublish()
activate Manga
Manga -> DB : UPDATE mangas SET est_public=0
DB --> Manga : OK
Manga --> CC : OK
deactivate Manga

== Republication après vérification ==
M -> CC : POST /mangas/{manga}/republish
activate CC
CC -> Manga : republish()
activate Manga
Manga -> DB : UPDATE mangas SET est_public=1,\ndate_derniere_republication=NOW()
DB --> Manga : OK
Manga --> CC : OK
deactivate Manga
CC --> M : redirect + "Manga republié"
deactivate CC

@enduml
